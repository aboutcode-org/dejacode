{
  "name": "dejacode-demo",
  "dockerComposeFile": "../docker-compose.codespaces.yml",
  "service": "web",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "overrideCommand": false,
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "DejaCode",
      "onAutoForward": "openBrowser"
    }
  }
}
