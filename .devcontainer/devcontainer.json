{
  "name": "dejacode-demo",
  "dockerComposeFile": "../docker-compose.codespaces.yml",
  "service": "web",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "overrideCommand": false,
  "postAttachCommand": "printf '\\n\\n  DejaCode:  https://%s-8000.%s\\n\\n' \"$CODESPACE_NAME\" \"$GITHUB_CODESPACES_PORT_FORWARDING_DOMAIN\"",
  "customizations": {
    "codespaces": {
      "openFiles": []
    },
    "vscode": {
      "settings": {
        "chat.disableAIFeatures": true,
        "workbench.startupEditor": "none"
      }
    }
  },
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "DejaCode",
      "onAutoForward": "notify"
    }
  }
}
